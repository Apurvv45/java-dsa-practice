package com.javadsapractice;

public class Sorted {
    public static int sorted(int[] arr){
        int size = arr.length;
        for (int i =0;i<size-1;i++){
            if (arr[i]>arr[i+1]){
                System.out.println("the element causing unsorting is : "+arr[i+1]);
            }
        }

        return 0;
    }
    public static void main(String[] args){
        int arr[]={1,2,3,5,4,6,7};
        sorted(arr);
    }
}
