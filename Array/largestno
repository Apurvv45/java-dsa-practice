package com.javadsapractice;

public class Max {

    public static int array(int[] arr){
        int max =0;
        int size = arr.length;
        for (int i=0;i<size;i++){
            if (arr[i]>max){
                max = arr[i];
            }

        }
        System.out.println("Largest no in array : "+max);
        return max;
    }
    public static void main(String []args){
        int arr[]={1,2,3,4,5,6,7};
        array(arr);
    }
}
