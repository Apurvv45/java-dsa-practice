package com.javadsapractice;

public class Array {


    public static double getavg(int arr[]){
        int sum =  0;
        for(int i=0;i < arr.length;i++){
            sum=sum+arr[i];
        }
        int size = arr.length;
        double avg = (double)sum/size;
        return avg;
    }

    public static void main(String[]args) {
        int arr[] = {2, 3, 4, 5};
        System.out.println("The avg is : " + getavg(arr));
    }

}
